def add_text_field(page, name, x0, top, x1, bottom, multiline=False, fontsize=9):
    page.insert_font(fontname=FONT_NAME, fontfile=FONT_PATH)
    w = fitz.Widget()
    w.field_name = name
    w.field_type = fitz.PDF_WIDGET_TYPE_TEXT
    w.rect = fitz.Rect(x0, top, x1, bottom)
    w.text_font = FONT_NAME          # font cu diacritice complete -> incadrare corecta pe cuvinte
    w.text_fontsize = fontsize
    w.fill_color = (0.85, 0.92, 1)   # fundal albastru pal, ca sa se vada unde se scrie
    w.border_color = None
    w.border_width = 0
    if multiline:
        w.field_flags = fitz.PDF_TX_FIELD_IS_MULTILINE
    page.add_widget(w)


def add_checkbox(page, name, x0, top, x1, bottom):
    w = fitz.Widget()
    w.field_name = name
    w.field_type = fitz.PDF_WIDGET_TYPE_CHECKBOX
    w.rect = fitz.Rect(x0, top, x1, bottom)
    w.field_value = False
    w.border_color = (0, 0, 0)
    w.border_width = 1
    w.fill_color = (1, 1, 1)
    page.add_widget(w)


def build_fillable_pdf(pages_definition, input_path, output_path):
    doc = fitz.open(input_path)
    num_pages = min(len(doc), len(pages_definition))
    for i in range(num_pages):
        page = doc[i]
        for field in pages_definition[i]:
            kind = field[0]
            if kind == "text":
                _, name, x0, top, x1, bottom, multiline, fontsize = field
                add_text_field(page, name, x0, top, x1, bottom, multiline, fontsize)
            elif kind == "checkbox":
                _, name, x0, top, x1, bottom = field
                add_checkbox(page, name, x0, top, x1, bottom)
            else:
                raise ValueError(f"Tip de camp necunoscut: {kind}")
    doc.save(output_path)


def main():
    if len(sys.argv) != 4 or sys.argv[1] not in TEMPLATES:
        print("Utilizare: python creeaza_pdf_completabil.py <sablon> input.pdf output.pdf")
        print(f"Sabloane disponibile: {', '.join(TEMPLATES)}")
        sys.exit(1)

    template_name, input_path, output_path = sys.argv[1], sys.argv[2], sys.argv[3]

    build_fillable_pdf(TEMPLATES[template_name], input_path, output_path)
    print(f"PDF completabil ('{template_name}') salvat la: {output_path}")


if __name__ == "__main__":
    main()


