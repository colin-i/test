def y_from_top(distance_from_top):
    return PAGE_HEIGHT - distance_from_top


def build_overlay(pages_definition):
    """Creeaza un PDF gol, transparent, cu campurile de formular definite
    in pages_definition (o lista de pagini, fiecare o lista de campuri)."""
    c = canvas.Canvas(OVERLAY_PATH, pagesize=(PAGE_WIDTH, PAGE_HEIGHT))
    form = c.acroForm

    def add_field(name, x0, top, x1, bottom, multiline=False, fontsize=9):
        y1 = y_from_top(bottom)
        y2 = y_from_top(top)
        height = y2 - y1
        kwargs = dict(
            name=name, tooltip=name,
            x=x0, y=y1, width=x1 - x0, height=height,
            borderStyle='underlined', borderColor=None, borderWidth=0,
            fillColor=Color(0.85, 0.92, 1, alpha=0.5),  # fundal albastru pal
            textColor=Color(0, 0, 0), fontSize=fontsize, forceBorder=False,
        )
        if multiline:
            kwargs['fieldFlags'] = 'multiline'
        form.textfield(**kwargs)

    def add_checkbox(name, x0, top, x1, bottom):
        y1 = y_from_top(bottom)
        size = min(x1 - x0, bottom - top)
        form.checkbox(
            name=name, tooltip=name,
            x=x0, y=y1, size=size,
            buttonStyle='check',
            borderStyle='solid', borderWidth=1, borderColor=Color(0, 0, 0),
            fillColor=Color(1, 1, 1), textColor=Color(0, 0, 0),
        )

    for page_fields in pages_definition:
        for field in page_fields:
            kind = field[0]
            if kind == "text":
                _, name, x0, top, x1, bottom, multiline, fontsize = field
                add_field(name, x0, top, x1, bottom, multiline, fontsize)
            elif kind == "checkbox":
                _, name, x0, top, x1, bottom = field
                add_checkbox(name, x0, top, x1, bottom)
            else:
                raise ValueError(f"Tip de camp necunoscut: {kind}")
        c.showPage()

    c.save()


def merge_overlay_into_original(input_path, output_path):
    """Combina PDF-ul original (neschimbat vizual) cu campurile din overlay,
    pagina cu pagina, rezultand un PDF completabil."""
    orig_reader = PdfReader(input_path)
    overlay_reader = PdfReader(OVERLAY_PATH)

    writer = PdfWriter()
    writer.append(orig_reader)

    num_pages = min(len(writer.pages), len(overlay_reader.pages))
    for i in range(num_pages):
        orig_page = writer.pages[i]
        overlay_page = overlay_reader.pages[i]

        overlay_annots = overlay_page.get("/Annots")
        cloned_refs = []
        if overlay_annots:
            for a in overlay_annots:
                obj = a.get_object()
                cloned = obj.clone(writer)
                ref = writer._add_object(cloned)
                cloned_refs.append(ref)
                cloned[NameObject("/P")] = orig_page.indirect_reference

        existing = orig_page.get("/Annots")
        if existing:
            for r in cloned_refs:
                existing.append(r)
        else:
            orig_page[NameObject("/Annots")] = ArrayObject(cloned_refs)

    overlay_acroform = overlay_reader.trailer["/Root"].get("/AcroForm")
    if overlay_acroform is not None:
        cloned_acroform = overlay_acroform.get_object().clone(writer)
        writer._root_object[NameObject("/AcroForm")] = cloned_acroform
        # NeedAppearances = True: asigura afisarea corecta a textului
        # introdus, in orice cititor de PDF (Acrobat, Preview, etc.)
        writer._root_object["/AcroForm"][NameObject("/NeedAppearances")] = BooleanObject(True)

    with open(output_path, "wb") as f:
        writer.write(f)


def main():
    if len(sys.argv) != 4 or sys.argv[1] not in TEMPLATES:
        print("Utilizare: python creeaza_pdf_completabil.py <sablon> input.pdf output.pdf")
        print(f"Sabloane disponibile: {', '.join(TEMPLATES)}")
        sys.exit(1)

    template_name, input_path, output_path = sys.argv[1], sys.argv[2], sys.argv[3]

    build_overlay(TEMPLATES[template_name])
    merge_overlay_into_original(input_path, output_path)
    print(f"PDF completabil ('{template_name}') salvat la: {output_path}")


if __name__ == "__main__":
    main()


