#!/usr/bin/env bash

#optional 1 file name

set -euo pipefail

CURRENT_DIR="$(pwd)"

# Strip $HOME/
REL="${CURRENT_DIR#$HOME/}"

# Remove first two directories
BASE=
for i in 1 2; do
  PART="${REL%%/*}"
  BASE="$BASE/$PART"
  if [[ "$REL" == */* ]]; then
    REL="${REL#*/}"
  else
    REL=""
  fi
done

# Check third directory (now first in REL)
if [[ -n "$REL" ]]; then
  FIRST_PART="${REL%%/*}"
  if [[ -L "$HOME$BASE/$FIRST_PART" ]]; then # it's a symlink
    #need to go to that project
    cd "$HOME$BASE"
    cd "$(readlink -f "$REL")"
    CURRENT_DIR="$(pwd)"

    # Remove it
    if [[ "$REL" == */* ]]; then
      REL="${REL#*/}"
    else
      REL=""
    fi
  fi
#else # we are already in the repo
#  cd "$HOME$BASE"
fi

#sanity check
IFS='/' read -ra parts <<< "$REL"
active_found=false
for p in "${parts[@]}"; do
  if [[ "$p" == "active" ]]; then
    echo sanity check failed regarding "'active'"
    exit 1
  fi
done

# Convert to a_b_c format
NAME="$(echo "$REL" | tr '/' '_')"

echo "Generated base: $NAME"

## Get latest release tag
#TAG="$(gh release view --json tagName -q .tagName)"
# Get the latest pre-release tag
TAG=$(gh release list --limit 1 --json tagName,isPrerelease \
	-q '.[] | select(.isPrerelease) | .tagName' | head -n1)

echo "Using release: $TAG"

upload_file() {
	file="$1"

	# all are files # [ -f "$file" ] || return

	sleep 1

	filename="$(basename "$file")"
	if [ -n "${NAME}" ]; then
		asset_name="${NAME}_${filename}"
	else
		asset_name="${filename}"
	fi

	echo "Uploading $filename as $asset_name"

	inter="$HOME/tmp/home/bc/activity/$asset_name" # --name in gh 2.46 is not

	# Symlink with the desired name
	cp -s "$file" "${inter}"

	echo "Uploading $asset_name"
	gh release upload "$TAG" "${inter}" --clobber || {
		rm "${inter}"
		exit 1
	}

	# Remove temp file
	rm "${inter}"
}

gh release view "$TAG" --json assets --jq '.assets | length'
# Upload files
#if [ -n "${1:-}" ]; then , - is to not fail from set -u
if [ "$#" -gt 0 ]; then
	for file in "$@"; do
		upload_file "$CURRENT_DIR/${file}"
	done
else
	for file in "$CURRENT_DIR"/*; do
		upload_file "$file"
	done
fi
gh release view "$TAG" --json assets --jq '.assets | length'
