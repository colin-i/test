
#optional 1 is number

name=$(basename `pwd`)

if [ -n "$1" ]; then
	ffmpeg -i ${name}$1.wav -t 2 -c copy b${name}.wav
	exit
fi

name=$(basename "$(pwd)")

find . -maxdepth 1 -type f -name "${name}[0-9][0-9].wav" | while read -r f; do
	base=$(basename "$f" .wav)
	out=_${base}.wav
	ffmpeg -loglevel error -i "$f" -t 2 -c copy "${out}"
	echo "Done: ${out}"
done
